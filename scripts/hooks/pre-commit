#!/usr/bin/env bash
# VibeCrafted custom pre-commit hook
set -e

echo "⚒  Running VibeCrafted pre-commit hooks..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

SH_FILES=()
PY_FILES=()
MD_YAML_FILES=()

while IFS= read -r file; do
    # Skip empty lines
    [ -z "$file" ] && continue
    
    case "$file" in
        *.sh|*.bash|*.zsh) SH_FILES+=("$file") ;;
        *.py) PY_FILES+=("$file") ;;
        *.md|*.yaml|*.yml) MD_YAML_FILES+=("$file") ;;
    esac
done <<< "$STAGED_FILES"

if [ ${#SH_FILES[@]} -gt 0 ]; then
    echo "▸ shellcheck"
    shellcheck -e SC1090,SC1091,SC2155,SC2034,SC2154 "${SH_FILES[@]}"
fi

if [ ${#PY_FILES[@]} -gt 0 ]; then
    echo "▸ ruff"
    ruff check --fix "${PY_FILES[@]}"
    ruff format "${PY_FILES[@]}"
    git add "${PY_FILES[@]}"
fi

if [ ${#MD_YAML_FILES[@]} -gt 0 ]; then
    echo "▸ prettier"
    npx prettier --write "${MD_YAML_FILES[@]}"
    git add "${MD_YAML_FILES[@]}"
fi

echo "✓ All pre-commit checks passed!"
