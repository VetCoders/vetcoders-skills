#!/usr/bin/env bash
# vibecraft — single entrypoint for the VibeCraft framework
# VibeCrafted with AI Agents (c)2026 VetCoders
set -euo pipefail

VIBECRAFT_HOME="${VIBECRAFTED_HOME:-$HOME/.vibecrafted}"
VIBECRAFT_SKILLS="$VIBECRAFT_HOME/skills"

# ── Colors (copper/steel palette, ANSI only) ──────────────────────
_bold='\033[1m'
_dim='\033[2m'
_copper='\033[38;5;173m'
_steel='\033[38;5;247m'
_green='\033[32m'
_yellow='\033[33m'
_cyan='\033[36m'
_red='\033[31m'
_reset='\033[0m'

# ── Helpers ───────────────────────────────────────────────────────
_version() {
  local vf="$VIBECRAFT_SKILLS/../VERSION"
  [[ -f "$vf" ]] || vf="$VIBECRAFT_HOME/tools/vibecrafted-current/VERSION"
  [[ -f "$vf" ]] && cat "$vf" || echo "?"
}

_ensure_helpers() {
  local helper="${XDG_CONFIG_HOME:-$HOME/.config}/vetcoders/vc-skills.sh"
  if [[ -r "$helper" ]]; then
    # shellcheck disable=SC1090
    source "$helper"
    return 0
  fi
  printf '%b[warn]%b Shell helpers not found. Run: make install\n' "$_yellow" "$_reset" >&2
  return 1
}

_agents=(claude codex gemini)
_skills=(implement research review plan prompt scaffold followup dou hydrate marbles decorate release prune justdo partner observe)

# ── Commands ──────────────────────────────────────────────────────

cmd_help() {
  local ver
  ver="$(_version)"
  printf '\n'
  printf '%b⚒  VibeCraft %s%b\n' "$_bold$_copper" "$ver" "$_reset"
  printf '%b─────────────────────────────────────────%b\n' "$_steel" "$_reset"
  printf '\n'
  printf '%bPipeline:%b  scaffold → init → workflow → followup → marbles → dou → decorate → hydrate → release\n' "$_bold" "$_reset"
  printf '%bModes:%b     partner (collaborative) · justdo (autonomous)\n' "$_bold" "$_reset"
  printf '%bResearch:%b  research (triple-agent) · delegate (in-session)\n' "$_bold" "$_reset"
  printf '%bQuality:%b   review · prune · screenscribe\n' "$_bold" "$_reset"
  printf '\n'
  printf '%bCommands:%b\n' "$_bold" "$_reset"
  printf '  %bvibecraft help%b                          This help\n' "$_cyan" "$_reset"
  printf '  %bvibecraft init%b [claude|codex|gemini]    Start interactive session with /vc-init\n' "$_cyan" "$_reset"
  printf '  %bvibecraft%b <agent> <skill> [args]        Spawn agent with skill\n' "$_cyan" "$_reset"
  printf '  %bvibecraft doctor%b                        Health check\n' "$_cyan" "$_reset"
  printf '  %bvibecraft dashboard%b                     Open Mission Control (zellij)\n' "$_cyan" "$_reset"
  printf '  %bvibecraft stats%b                         Today'\''s agent runs and token usage\n' "$_cyan" "$_reset"
  printf '  %bvibecraft uninstall%b                     Reverse everything\n' "$_cyan" "$_reset"
  printf '\n'
  printf '%bAgent × Skill matrix:%b\n' "$_bold" "$_reset"
  printf '  %b<agent>%b = claude, codex, or gemini\n' "$_copper" "$_reset"
  printf '  %b<skill>%b = implement · research · review · plan · prompt\n' "$_copper" "$_reset"
  printf '            scaffold · followup · dou · hydrate · marbles\n'
  printf '            decorate · release · prune · justdo · partner · observe\n'
  printf '\n'
  printf '%bExamples:%b\n' "$_dim" "$_reset"
  printf '  vibecraft init claude\n'
  printf '  vibecraft codex implement plan.md\n'
  printf '  vibecraft claude research "state of auth libraries 2026"\n'
  printf '  vibecraft codex marbles "fix all P0 findings"\n'
  printf '  vibecraft gemini followup\n'
  printf '\n'
  printf '%bPaths:%b\n' "$_dim" "$_reset"
  printf '  Skills:     %s/skills/\n' "$VIBECRAFT_HOME"
  printf '  Artifacts:  %s/artifacts/<org>/<repo>/<YYYY_MMDD>/\n' "$VIBECRAFT_HOME"
  printf '  Inbox:      %s/inbox/\n' "$VIBECRAFT_HOME"
  printf '\n'
}

cmd_init() {
  local agent="${1:-claude}"
  _ensure_helpers || return 1

  case "$agent" in
    claude|codex|gemini) ;;
    *) printf '%b[error]%b Unknown agent: %s. Use claude, codex, or gemini.\n' "$_red" "$_reset" "$agent" >&2; return 1 ;;
  esac

  printf '%b⚒%b  Starting %b%s%b interactive session with /vc-init...\n' "$_copper" "$_reset" "$_bold" "$agent" "$_reset"

  case "$agent" in
    claude) claude -i "Run /vc-init on this repository. Give me full context." ;;
    codex)  codex -i "Run /vc-init on this repository. Give me full context." ;;
    gemini) gemini -i "Run /vc-init on this repository. Give me full context." ;;
  esac
}

cmd_agent() {
  local agent="$1"
  local skill="$2"
  shift 2

  _ensure_helpers || return 1

  # Validate agent
  local valid_agent=0
  for a in "${_agents[@]}"; do [[ "$a" == "$agent" ]] && valid_agent=1; done
  if (( !valid_agent )); then
    printf '%b[error]%b Unknown agent: %s\n' "$_red" "$_reset" "$agent" >&2
    return 1
  fi

  # Validate skill
  local valid_skill=0
  for s in "${_skills[@]}"; do [[ "$s" == "$skill" ]] && valid_skill=1; done
  if (( !valid_skill )); then
    printf '%b[error]%b Unknown skill: %s\n' "$_red" "$_reset" "$skill" >&2
    printf '  Available: %s\n' "${_skills[*]}"
    return 1
  fi

  # Dispatch to shell helper
  local helper="${agent}-${skill}"
  if command -v "$helper" >/dev/null 2>&1; then
    "$helper" "$@"
  else
    printf '%b[error]%b Helper %s not found. Run: make install\n' "$_red" "$_reset" "$helper" >&2
    return 1
  fi
}

cmd_doctor() {
  local makefile=""
  # Find the Makefile
  for candidate in \
    "$VIBECRAFT_HOME/tools/vibecrafted-current/Makefile" \
    "$(git rev-parse --show-toplevel 2>/dev/null)/Makefile"; do
    if [[ -f "$candidate" ]]; then
      makefile="$candidate"
      break
    fi
  done

  if [[ -z "$makefile" ]]; then
    printf '%b[error]%b Makefile not found. Is VibeCraft installed?\n' "$_red" "$_reset" >&2
    return 1
  fi

  make -C "$(dirname "$makefile")" doctor
}

cmd_dashboard() {
  _ensure_helpers || return 1
  if command -v vc-dashboard >/dev/null 2>&1; then
    vc-dashboard
  elif command -v zellij >/dev/null 2>&1; then
    local layout
    for candidate in \
      "$VIBECRAFT_SKILLS/vc-agents/config/zellij/layouts/mission-control.kdl" \
      "$VIBECRAFT_HOME/tools/vibecrafted-current/config/zellij/layouts/mission-control.kdl"; do
      [[ -f "$candidate" ]] && layout="$candidate" && break
    done
    if [[ -n "${layout:-}" ]]; then
      zellij --layout "$layout" --session vibecraft-mc
    else
      printf '%b[warn]%b Mission control layout not found.\n' "$_yellow" "$_reset" >&2
      printf '  Run: vibecraft doctor\n'
    fi
  else
    printf '%b[warn]%b zellij not installed. Install it for Mission Control.\n' "$_yellow" "$_reset" >&2
  fi
}

cmd_stats() {
  local today_dir artifacts_dir
  today_dir="$(date +%Y_%m%d)"
  artifacts_dir="$VIBECRAFT_HOME/artifacts"

  printf '\n%b⚒  VibeCraft Stats — %s%b\n' "$_bold$_copper" "$(date +%Y-%m-%d)" "$_reset"
  printf '%b─────────────────────────────────────────%b\n' "$_steel" "$_reset"

  if [[ ! -d "$artifacts_dir" ]]; then
    printf '  No artifacts found yet.\n\n'
    return 0
  fi

  # Collect today's meta files via date directory
  local -a metas=()
  while IFS= read -r f; do
    metas+=("$f")
  done < <(find "$artifacts_dir" -path "*${today_dir}*" -name "*.meta.json" -type f 2>/dev/null | sort -r)

  local total=${#metas[@]}
  if (( total == 0 )); then
    printf '  No runs today.\n\n'
    return 0
  fi

  local completed=0 failed=0 running=0
  local agents_seen="" line st ag mo ri

  for meta in "${metas[@]}"; do
    line="$(jq -r '[.status // "?", .agent // "?", .mode // "-", .run_id // "-"] | join("\t")' "$meta" 2>/dev/null)" || continue
    IFS=$'\t' read -r st ag mo ri <<< "$line"
    case "$st" in
      completed)         completed=$(( completed + 1 )) ;;
      failed)            failed=$(( failed + 1 )) ;;
      launching|running) running=$(( running + 1 )) ;;
    esac
    agents_seen="$agents_seen $ag"
  done

  local distinct_agents
  distinct_agents="$(printf '%s\n' $agents_seen | sort -u | sed '/^$/d' | tr '\n' ' ')"

  printf '  Runs today    %b%d%b  ' "$_bold" "$total" "$_reset"
  [[ $completed -gt 0 ]] && printf '%b%d ✓%b  ' "$_green" "$completed" "$_reset"
  [[ $failed -gt 0 ]]    && printf '%b%d ✗%b  ' "$_red" "$failed" "$_reset"
  [[ $running -gt 0 ]]   && printf '%b%d ⟳%b  ' "$_yellow" "$running" "$_reset"
  printf '\n'
  printf '  Agents        %s\n' "${distinct_agents:-none}"
  printf '\n'

  printf '  %bRecent:%b\n' "$_bold" "$_reset"
  local count=0
  for meta in "${metas[@]}"; do
    [[ $count -ge 8 ]] && break
    line="$(jq -r '[.status // "?", .agent // "?", .mode // "-", .run_id // "-"] | join("\t")' "$meta" 2>/dev/null)" || continue
    IFS=$'\t' read -r st ag mo ri <<< "$line"
    local color="$_dim"
    case "$st" in
      completed)         color="$_green" ;;
      failed)            color="$_red" ;;
      launching|running) color="$_yellow" ;;
    esac
    printf '    %b%-10s%b %-8s %-12s %s\n' "$color" "$st" "$_reset" "$ag" "$mo" "$ri"
    count=$(( count + 1 ))
  done
  printf '\n'
}

cmd_uninstall() {
  local makefile=""
  for candidate in \
    "$VIBECRAFT_HOME/tools/vibecrafted-current/Makefile" \
    "$(git rev-parse --show-toplevel 2>/dev/null)/Makefile"; do
    [[ -f "$candidate" ]] && makefile="$candidate" && break
  done

  if [[ -z "$makefile" ]]; then
    printf '%b[error]%b Makefile not found.\n' "$_red" "$_reset" >&2
    return 1
  fi

  make -C "$(dirname "$makefile")" uninstall
}

cmd_unknown() {
  local attempted="$1"
  printf '\n'
  printf '%b⚒%b  "%s" isn'\''t a command yet, but we admire the enthusiasm.\n' "$_copper" "$_reset" "$attempted"
  printf '\n'
  printf '  %bvibecraft help%b        see what we can do\n' "$_cyan" "$_reset"
  printf '  %bvibecraft init%b        start your first session\n' "$_cyan" "$_reset"
  printf '  %bvibecraft doctor%b      check installation health\n' "$_cyan" "$_reset"
  printf '\n'
}

# ── Router ────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    help|-h|--help)
      cmd_help
      ;;
    init)
      cmd_init "$@"
      ;;
    doctor|check)
      cmd_doctor
      ;;
    dashboard|mc|mission-control)
      cmd_dashboard
      ;;
    stats|status)
      cmd_stats
      ;;
    uninstall|remove)
      cmd_uninstall
      ;;
    version|--version|-v)
      printf 'vibecraft %s\n' "$(_version)"
      ;;

    # Agent dispatch: vibecraft <agent> <skill> [args]
    claude|codex|gemini)
      local skill="${1:-}"
      if [[ -z "$skill" ]]; then
        printf '%b[error]%b Missing skill. Usage: vibecraft %s <skill> [args]\n' "$_red" "$_reset" "$cmd" >&2
        printf '  Skills: %s\n' "${_skills[*]}"
        return 1
      fi
      shift
      cmd_agent "$cmd" "$skill" "$@"
      ;;

    *)
      cmd_unknown "$cmd"
      ;;
  esac
}

main "$@"
