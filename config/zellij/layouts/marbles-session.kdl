// Marbles Session — convergence workspace
// Launch: zellij --layout marbles-session
//
// Skroty widoczne w dolnym pasku:
//   Ctrl+P  Pause marbles
//   Alt+R   Resume
//   Ctrl+X  Stop
//   Alt+S   Session list
//   Alt+I   Inspect

layout {
// Top bar: tabs
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }

// Main workspace
    tab name="Marbles" focus=true {
        pane split_direction="vertical" {
        // Left: your working terminal (focus here)
            pane name="terminal" size="60%" focus=true
        // Right: second pane for agent output or monitoring
            pane name="agent" size="40%"
        }
    }

// Bottom bar: shows keybindings (the important one!)
    pane size=2 borderless=true {
        plugin location="status-bar"
    }
}
