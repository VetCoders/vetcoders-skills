#!/usr/bin/env bash
# vibecrafted-husky-template :: commit-msg
#
# Conventional Commits with optional [<agent>/<workflow>] prefix.
#
#   <type>(<scope>): <subject>
#   [<agent>/<workflow>] <type>(<scope>): <subject>
#
# Types: feat fix docs style refactor perf test build ci chore revert
# Subject: 1..$HUSKY_COMMIT_MSG_SUBJECT_MAX chars after the colon
#
# Vibecrafted with AI Agents by VetCoders (c)2024-2026 LibraxisAI

set -euo pipefail

HUSKY_LIB="${BASH_SOURCE[0]%/*}/lib"
# shellcheck disable=SC1090,SC1091
. "$HUSKY_LIB/core.sh"
husky_init

[ "$HUSKY_COMMIT_MSG_CONVENTIONAL" = "1" ] || exit 0

MSG_FILE="$1"

# Skip merge / fixup / squash commits — they have a fixed prefix.
first_line="$(head -n1 "$MSG_FILE" | tr -d '\r')"
case "$first_line" in
  "Merge "*|"Revert "*|"fixup!"*|"squash!"*|"amend!"*) exit 0 ;;
esac

types='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'
agent_prefix='\[[a-z0-9][a-z0-9_-]*\/[a-z0-9][a-z0-9_-]*\] '

if [ "$HUSKY_COMMIT_MSG_ALLOW_AGENT_PREFIX" = "1" ]; then
  pattern="^(${agent_prefix})?(${types})(\\(.+\\))?: .{1,${HUSKY_COMMIT_MSG_SUBJECT_MAX}}$"
else
  pattern="^(${types})(\\(.+\\))?: .{1,${HUSKY_COMMIT_MSG_SUBJECT_MAX}}$"
fi

if printf '%s' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

husky_err "Invalid commit message subject."
husky_log
husky_log "Format:  <type>(<scope>): <subject>"
if [ "$HUSKY_COMMIT_MSG_ALLOW_AGENT_PREFIX" = "1" ]; then
  husky_log "     or  [<agent>/<workflow>] <type>(<scope>): <subject>"
fi
husky_log
husky_log "Types:   ${types//|/, }"
husky_log "Subject: 1..${HUSKY_COMMIT_MSG_SUBJECT_MAX} chars after the colon"
husky_log
husky_log "Examples:"
husky_log "  feat: add Unicode search to Studio"
husky_log "  fix(api): handle empty query gracefully"
if [ "$HUSKY_COMMIT_MSG_ALLOW_AGENT_PREFIX" = "1" ]; then
  husky_log "  [claude/vc-workflow] refactor(studio): stylizer reuses backend engine"
fi
exit 1
