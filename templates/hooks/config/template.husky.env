# vibecrafted-husky-template — repo-local configuration
#
# Copy → .husky/config.env, then enable the steps your repo actually has.
# Every flag defaults to OFF unless this file explicitly turns it on.
#
# Lookup order:
#   1. Environment variables in the shell that invoked git
#   2. .husky/config.env (this file)
#   3. Built-in defaults in lib/core.sh

# ============================================================================
# WARN mode
# ============================================================================
# When the current branch is NOT protected and HUSKY_WARN_MODE_ON_FEATURE=1,
# blocking failures get demoted to warnings, logged to .husky/warns/, and
# attached to the commit message as Vibecrafted-Warn-Signature trailer.
# Two consecutive warnings with the same signature escalate back to strict.
HUSKY_WARN_MODE_ON_FEATURE=1

# Regex for protected branches that always run strict.
HUSKY_WARN_PROTECTED_BRANCHES='^(main|develop|release/.*|hotfix/.*)$'

# How many warn-log files to keep per hook (rolling).
HUSKY_WARN_RETENTION=5

# One-off overrides:
#   HUSKY_STRICT=1     → force strict regardless of branch
#   HUSKY_WARN_FORCE=1 → force WARN regardless of branch
# Set in shell, not here.

# ============================================================================
# Pre-commit — runs on staged files only (fast)
# ============================================================================

# Secret leak guard — strict regex (sk-, ghp_, AKIA, AIza, vista-, Bearer, ...)
HUSKY_PRECOMMIT_SECRETS=1

# Block .env / .env.* / credentials files from being staged
HUSKY_PRECOMMIT_ENV_FILES=1

# lint-staged (auto-formats + re-stages)
HUSKY_PRECOMMIT_LINT_STAGED=1

# Stage-scoped formatters (alternative to lint-staged for repos without it)
HUSKY_PRECOMMIT_PRETTIER_STAGED=0
HUSKY_PRECOMMIT_ESLINT_STAGED=0
HUSKY_PRECOMMIT_STYLELINT_STAGED=0

# TypeScript check on staged .ts/.tsx (slow on cold cache)
HUSKY_PRECOMMIT_TSC=0

# Semgrep on staged files only (fast)
HUSKY_PRECOMMIT_SEMGREP_STAGED=0

# Loctree structural health check (non-blocking even when on)
HUSKY_PRECOMMIT_LOCT_HEALTH=0

# Loctree suppression budget check — fails if silencers exceed budget
HUSKY_PRECOMMIT_LOCT_SUPPRESSIONS=0
HUSKY_PRECOMMIT_LOCT_SUPPRESSIONS_BUDGET=30  # total silencers across repo

# Rust toolchain
HUSKY_PRECOMMIT_RUSTFMT_STAGED=0
HUSKY_PRECOMMIT_RUST_CARGO_CHECK=0
# Subdir where Cargo.toml lives (default: . or src-tauri/)
HUSKY_RUST_CARGO_DIR='.'

# Python toolchain
HUSKY_PRECOMMIT_PY_RUFF=0
HUSKY_PRECOMMIT_PY_BLACK=0

# Shell toolchain
HUSKY_PRECOMMIT_SH_SHELLCHECK=0

# ============================================================================
# Pre-push — full-repo gates (slow but thorough)
# ============================================================================

# Full prettier --check across the repo
HUSKY_PREPUSH_PRETTIER_FULL=0

# Full semgrep --config auto on entire repo (with .semgrepignore respected)
HUSKY_PREPUSH_SEMGREP_FULL=0

# Repo-wide tsc --noEmit
HUSKY_PREPUSH_TSC=0

# Loctree: detect circular imports
HUSKY_PREPUSH_LOCT_CYCLES=0

# Loctree: FE↔BE contract verification (Tauri / multi-module repos)
HUSKY_PREPUSH_LOCT_COMMANDS=0

# Vitest unit tests
HUSKY_PREPUSH_VITEST=0

# Rust gates
HUSKY_PREPUSH_CARGO_CLIPPY=0   # -D warnings
HUSKY_PREPUSH_CARGO_TEST=0

# Secret guard on pushed diff (always runs if PUSH refs available)
HUSKY_PREPUSH_SECRETS=1

# ============================================================================
# Commit-msg
# ============================================================================
HUSKY_COMMIT_MSG_CONVENTIONAL=1

# Allow optional [<agent>/<workflow>] prefix (e.g. [claude/vc-init] feat: ...)
HUSKY_COMMIT_MSG_ALLOW_AGENT_PREFIX=1

# Max subject length after the colon
HUSKY_COMMIT_MSG_SUBJECT_MAX=100

# ============================================================================
# Pre-merge-commit
# ============================================================================

# Clean codex-agent/ artifacts when merging from codex/* into non-codex branch
HUSKY_PREMERGE_CLEAN_CODEX_AGENT=1

# Generic vendored-path cleanup (one path per line)
HUSKY_PREMERGE_CLEAN_PATHS=''

# ============================================================================
# Post-commit
# ============================================================================

# Warn if Claude-artifact filenames landed in commit (RAPORT_*, _SESSION_*, etc.)
HUSKY_POSTCOMMIT_CLAUDE_ARTIFACT_WARN=1

# ============================================================================
# Exclude paths from lint routing (one per line, glob-style)
# ============================================================================
HUSKY_EXCLUDE_PATHS='
node_modules/
dist/
.loctree/
target/
vendor/
.next/
build/
.husky/_/
'

# ============================================================================
# Sensitive-file blocklist for pre-push (push of these is always blocked)
# ============================================================================
HUSKY_BLOCKED_PATHS='
.env
.env.local
.env.production
.env.staging
LibraxisAI-*.md
CLAUDE.local.md
'
